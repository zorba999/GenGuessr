# GenLayer deployer private key (server-side only, never expose to client)
PRIVATE_KEY=0x...

# Deployed contract address (after running npm run deploy-contract)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# GenLayer Bradbury testnet RPC
NEXT_PUBLIC_GENLAYER_RPC=https://rpc-bradbury.genlayer.com

# WalletConnect project ID (get free from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
